---
import type { Project } from '../data/projects';

type ProofNode = {
  label: string;
  meta: string;
  status: string;
  x: number;
  y: number;
};

type ProofEdge = {
  source: number;
  target: number;
};

type ProofItem = {
  title: string;
  caption: string;
  nodes: ProofNode[];
  side: string[];
};

type Props = {
  project: Project;
};

const { project } = Astro.props;

const defaultEdges: ProofEdge[] = [
  { source: 0, target: 1 },
  { source: 1, target: 2 },
  { source: 2, target: 3 }
];

const portOffset = 9;

function getEdgePath(source: ProofNode, target: ProofNode) {
  const sourceX = source.x + portOffset;
  const sourceY = source.y;
  const targetX = target.x - portOffset;
  const targetY = target.y;
  const bend = Math.max(18, Math.abs(target.x - source.x) * 0.68);

  return `M ${sourceX} ${sourceY} C ${sourceX + bend} ${sourceY}, ${targetX - bend} ${targetY}, ${targetX} ${targetY}`;
}

const proofBySlug: Record<string, ProofItem> = {
  'cinematic-ai': {
    title: 'Workflow surface',
    caption: 'A compact view of the core product promise: model, prompt, input, transform, and review stay visible as one repeatable pipeline.',
    nodes: [
      { label: 'Input', meta: 'brief + references', status: 'ready', x: 20, y: 28 },
      { label: 'Prompt', meta: 'creative direction', status: 'running', x: 40, y: 58 },
      { label: 'Model', meta: 'generation step', status: 'queued', x: 60, y: 28 },
      { label: 'Review', meta: 'inspect output', status: 'complete', x: 80, y: 58 }
    ],
    side: ['Visible execution state', 'Reusable node patterns', 'Debuggable creative flow']
  },
  'cafe-maps': {
    title: 'Map/list decision loop',
    caption: 'Cafe discovery becomes faster when spatial context, curated tags, and place details stay coordinated on the same screen.',
    nodes: [
      { label: 'Area', meta: 'nearby search', status: 'map', x: 20, y: 58 },
      { label: 'Mood', meta: 'quiet / work', status: 'filter', x: 40, y: 28 },
      { label: 'Cafe', meta: 'selected pin', status: 'active', x: 60, y: 58 },
      { label: 'Detail', meta: 'decide fast', status: 'open', x: 80, y: 28 }
    ],
    side: ['Map-first browsing', 'Curated context tags', 'Mobile place detail']
  },
  'study-stream': {
    title: 'Session state',
    caption: 'The useful realtime story is the room state: people join, signal readiness, focus, break, and complete without adding noise.',
    nodes: [
      { label: 'Lobby', meta: 'join room', status: 'open', x: 20, y: 28 },
      { label: 'Ready', meta: 'group signal', status: 'synced', x: 40, y: 58 },
      { label: 'Focus', meta: 'timer running', status: 'live', x: 60, y: 28 },
      { label: 'Break', meta: 'quiet reset', status: 'next', x: 80, y: 58 }
    ],
    side: ['Clear room lifecycle', 'Low-noise presence', 'Repeatable focus rhythm']
  },
  'engineering-focus': {
    title: 'Frontend boundaries',
    caption: 'This page works best as principles made concrete: static Astro shells, focused React islands, markdown content, and one visual system.',
    nodes: [
      { label: 'Astro', meta: 'page shell', status: 'static', x: 20, y: 28 },
      { label: 'Content', meta: 'markdown data', status: 'source', x: 40, y: 58 },
      { label: 'React', meta: 'motion islands', status: 'client', x: 60, y: 28 },
      { label: 'Tailwind', meta: 'design tokens', status: 'system', x: 80, y: 58 }
    ],
    side: ['Small component surface', 'Evidence-led claims', 'Consistent design rules']
  }
};

const proof = proofBySlug[project.slug];
---

{
  proof && (
    <div class="mb-12 overflow-hidden rounded-[8px] bg-[#101010] ring-1 ring-primary/10 sm:mb-14">
      <div class="grid gap-1 lg:grid-cols-[minmax(0,1.4fr)_minmax(280px,0.6fr)]">
        <div class="relative min-h-[320px] overflow-hidden bg-[#171717] p-5 sm:min-h-[380px] sm:p-6">
          <div class="bg-noise pointer-events-none absolute inset-0 opacity-[0.08]"></div>
          <div class="project-proof-grid absolute inset-0"></div>
          <svg class="pointer-events-none absolute inset-0 z-10 h-full w-full" viewBox="0 0 100 80" role="img" aria-label={`${project.title} ${proof.title}`} preserveAspectRatio="none">
            <defs>
              <filter id={`proof-glow-${project.slug}`} x="-40%" y="-40%" width="180%" height="180%">
                <feGaussianBlur stdDeviation="1.15" result="blur" />
                <feMerge>
                  <feMergeNode in="blur" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>
              <marker id={`proof-arrow-${project.slug}`} viewBox="0 0 10 10" refX="8" refY="5" markerWidth="4" markerHeight="4" orient="auto-start-reverse">
                <path d="M 1 1 L 9 5 L 1 9 z" fill="#c5ff41" fill-opacity="0.78" />
              </marker>
            </defs>
            {defaultEdges.map((edge, index) => {
              const source = proof.nodes[edge.source];
              const target = proof.nodes[edge.target];
              const edgePath = getEdgePath(source, target);

              return (
                <g class="project-proof-edge" style={`--edge-index: ${index}`}>
                  <path d={edgePath} class="project-proof-edge-halo" pathLength="1" stroke="#c5ff41" stroke-opacity="0.2" stroke-width="9" stroke-linecap="round" />
                  <path d={edgePath} class="project-proof-edge-line" pathLength="1" stroke="#c5ff41" stroke-opacity="0.92" stroke-width="2.4" stroke-linecap="round" filter={`url(#proof-glow-${project.slug})`} marker-end={`url(#proof-arrow-${project.slug})`} />
                  <path d={edgePath} class="project-proof-edge-pulse" pathLength="1" stroke="#e1e0cc" stroke-opacity="0.95" stroke-width="3" stroke-linecap="round" />
                </g>
              );
            })}
          </svg>
          {proof.nodes.map((node, index) => (
            <div class="project-proof-node absolute z-20 w-[118px] rounded-[8px] border border-primary/15 bg-black/80 p-3 shadow-2xl shadow-black/45 backdrop-blur sm:w-[168px] sm:p-4" data-node-index={String(index)} style={`--node-x: ${node.x}%; --node-y: ${node.y}%;`}>
              <span class="project-proof-port project-proof-port-in"></span>
              <span class="project-proof-port project-proof-port-out"></span>
              <div class="flex items-center justify-between gap-3">
                <p class="text-sm leading-none text-[#E1E0CC] sm:text-base">{node.label}</p>
                <span class="h-2 w-2 rounded-full bg-[#e1e0cc] shadow-[0_0_18px_rgba(197,255,65,0.45)]"></span>
              </div>
              <p class="mt-3 text-[11px] leading-snug text-gray-500 sm:text-xs">{node.meta}</p>
              <p class="mt-4 text-[10px] uppercase tracking-[0.2em] text-primary/70">{node.status}</p>
            </div>
          ))}
        </div>
        <div class="flex flex-col justify-between gap-8 p-5 sm:p-6">
          <div>
            <p class="text-xs uppercase tracking-[0.22em] text-primary/70">Artifact</p>
            <h2 class="mt-5 text-2xl font-normal leading-none text-[#E1E0CC] sm:text-3xl">{proof.title}</h2>
            <p class="mt-5 text-sm leading-relaxed text-gray-400 sm:text-base">{proof.caption}</p>
          </div>
          <ul class="grid gap-3">
            {proof.side.map((item) => (
              <li class="border-l border-primary/30 pl-4 text-sm leading-relaxed text-gray-400">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  )
}

<style>
  .project-proof-grid {
    background-image:
      radial-gradient(circle at 50% 48%, rgba(197, 255, 65, 0.1), transparent 34%),
      linear-gradient(rgba(225, 224, 204, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(225, 224, 204, 0.045) 1px, transparent 1px);
    background-size: 100% 100%, 36px 36px, 36px 36px;
    mask-image: radial-gradient(circle at center, black 0%, black 58%, transparent 86%);
  }

  .project-proof-edge-halo,
  .project-proof-edge-line,
  .project-proof-edge-pulse {
    fill: none;
    vector-effect: non-scaling-stroke;
  }

  .project-proof-edge-halo {
    opacity: 1;
  }

  .project-proof-edge-line {
    opacity: 1;
  }

  .project-proof-edge-pulse {
    animation: proof-flow 3.8s linear infinite;
    animation-delay: calc(var(--edge-index) * -0.75s);
    stroke-dasharray: 0.1 0.9;
  }

  .project-proof-node {
    left: var(--node-x);
    top: var(--node-y);
    transform: translate(-50%, -50%);
    background-image: linear-gradient(135deg, rgba(255, 255, 255, 0.045), transparent 42%);
  }

  .project-proof-node::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    box-shadow: inset 0 1px 0 rgba(225, 224, 204, 0.08);
  }

  .project-proof-port {
    position: absolute;
    top: 50%;
    width: 11px;
    height: 11px;
    border: 1px solid rgba(197, 255, 65, 0.56);
    border-radius: 999px;
    background: #171717;
    box-shadow: 0 0 0 4px rgba(197, 255, 65, 0.08), 0 0 18px rgba(197, 255, 65, 0.25);
    transform: translateY(-50%);
    z-index: 30;
  }

  .project-proof-port-in {
    left: -6px;
  }

  .project-proof-port-out {
    right: -6px;
  }

  @keyframes proof-flow {
    from {
      stroke-dashoffset: 1;
    }
    to {
      stroke-dashoffset: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-proof-edge-pulse {
      animation: none;
    }
  }

  @media (max-width: 639px) {
    .project-proof-node {
      width: 104px;
    }

  }
</style>
