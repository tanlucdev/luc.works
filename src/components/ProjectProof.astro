---
import type { Project } from '../data/projects';

type Props = {
  project: Project;
};

const { project } = Astro.props;
const media = project.media ?? {
  type: 'mockup',
  title: 'Product evidence',
  caption: 'A product-style artifact showing the core interaction and system shape.'
};
const moments = project.proofMoments ?? [];

const rails = {
  'cinematic-ai': ['Brief', 'Prompt', 'Model', 'Review'],
  'cafe-maps': ['District', 'Mood', 'Pinned', 'Detail'],
  'study-stream': ['Lobby', 'Ready', 'Focus', 'Break'],
  'engineering-focus': ['Astro', 'Content', 'React', 'Ship']
};

const labels = rails[project.slug as keyof typeof rails] ?? rails['engineering-focus'];
---

<section class="project-proof" aria-labelledby={`proof-${project.slug}`}>
  <div class="project-proof__visual" aria-label={`${project.title} ${media.title} mockup`}>
    {project.slug === 'cafe-maps' ? (
      <div class="map-mock">
        <div class="map-mock__grid"></div>
        <span class="pin pin--one"></span>
        <span class="pin pin--two pin--active"></span>
        <span class="pin pin--three"></span>
        <div class="map-mock__list">
          <p>Quiet work</p>
          <strong>Three O'Clock</strong>
          <span>District 3 / Wi-Fi / calm tables</span>
        </div>
        <div class="map-mock__sheet">
          <span>Selected place</span>
          <strong>Open until 22:00</strong>
          <p>Enough light, low music, two-seat corners.</p>
        </div>
      </div>
    ) : project.slug === 'study-stream' ? (
      <div class="session-mock">
        <div class="session-mock__timer">42:18</div>
        <div class="session-mock__bar"><span></span></div>
        <div class="session-mock__people">
          <span>Ready</span>
          <span>Focusing</span>
          <span>Muted</span>
        </div>
        <div class="session-mock__feed">
          <p>Minh joined the room</p>
          <p>Group focus started</p>
          <p>Break in 12 minutes</p>
        </div>
      </div>
    ) : project.slug === 'engineering-focus' ? (
      <div class="architecture-mock">
        {labels.map((label, index) => (
          <div class="architecture-mock__node" style={`--i:${index}`}>
            <span>{label}</span>
            <small>{index === 0 ? 'page shell' : index === 1 ? 'markdown' : index === 2 ? 'island' : 'verify'}</small>
          </div>
        ))}
      </div>
    ) : (
      <div class="workflow-mock">
        {labels.map((label, index) => (
          <div class="workflow-mock__node" style={`--i:${index}`}>
            <span>{label}</span>
            <small>{index === 1 ? 'running' : index === 3 ? 'complete' : 'ready'}</small>
          </div>
        ))}
        <div class="workflow-mock__debug">
          <span>Debug panel</span>
          <strong>Missing reference frame</strong>
          <p>Node pauses close to the failure instead of hiding the error in logs.</p>
        </div>
      </div>
    )}
  </div>

  <div class="project-proof__copy">
    <p class="project-proof__label">{media.type === 'mockup' ? 'Product mockup' : 'Project media'}</p>
    <h2 id={`proof-${project.slug}`}>{media.title}</h2>
    <p>{media.caption}</p>
    {project.availability && <p class="project-proof__availability">{project.availability}</p>}
  </div>

  {moments.length > 0 && (
    <div class="project-proof__moments" aria-label={`${project.title} proof moments`}>
      {moments.slice(0, 3).map((moment) => (
        <article>
          <p>{moment.caption}</p>
          <h3>{moment.title}</h3>
          <span>{moment.body}</span>
        </article>
      ))}
    </div>
  )}
</section>

<style>
  .project-proof {
    display: grid;
    gap: 1px;
    margin-bottom: 3.5rem;
    overflow: hidden;
    border-radius: 8px;
    background: rgba(225, 224, 204, 0.1);
  }

  .project-proof__visual,
  .project-proof__copy,
  .project-proof__moments article {
    background: #101010;
  }

  .project-proof__visual {
    position: relative;
    min-height: 420px;
    overflow: hidden;
    padding: 1.5rem;
  }

  .project-proof__visual::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 50% 40%, rgba(222, 219, 200, 0.09), transparent 34%),
      linear-gradient(rgba(225, 224, 204, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(225, 224, 204, 0.045) 1px, transparent 1px);
    background-size: 100% 100%, 36px 36px, 36px 36px;
    mask-image: radial-gradient(circle at center, black 0%, black 60%, transparent 88%);
  }

  .project-proof__copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1.5rem;
  }

  .project-proof__label,
  .project-proof__moments p {
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(222, 219, 200, 0.7);
  }

  .project-proof__copy h2 {
    margin-top: 1.25rem;
    font-size: clamp(1.75rem, 3vw, 2.6rem);
    font-weight: 400;
    line-height: 1;
    color: #E1E0CC;
  }

  .project-proof__copy > p:not(.project-proof__label) {
    margin-top: 1.25rem;
    max-width: 34rem;
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgb(156 163 175);
  }

  .project-proof__availability {
    border-left: 1px solid rgba(222, 219, 200, 0.28);
    padding-left: 1rem;
  }

  .project-proof__moments {
    display: grid;
    gap: 1px;
  }

  .project-proof__moments article {
    min-height: 180px;
    padding: 1.25rem;
  }

  .project-proof__moments h3 {
    margin-top: 1.25rem;
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.1;
    color: #E1E0CC;
  }

  .project-proof__moments span {
    display: block;
    margin-top: 1rem;
    font-size: 0.9rem;
    line-height: 1.65;
    color: rgb(156 163 175);
  }

  .workflow-mock,
  .map-mock,
  .session-mock,
  .architecture-mock {
    position: absolute;
    inset: 1.5rem;
    z-index: 1;
  }

  .workflow-mock__node,
  .architecture-mock__node {
    position: absolute;
    left: calc(12% + var(--i) * 22%);
    top: calc(32% + (var(--i) % 2) * 28%);
    width: min(11rem, 34vw);
    border: 1px solid rgba(222, 219, 200, 0.18);
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.72);
    padding: 1rem;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.34);
    transform: translate(-50%, -50%);
  }

  .workflow-mock__node::after,
  .architecture-mock__node::after {
    content: '';
    position: absolute;
    top: 50%;
    left: calc(100% + 0.25rem);
    width: 7rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(222, 219, 200, 0.7), transparent);
    transform: translateY(-50%);
  }

  .workflow-mock__node:last-of-type::after,
  .architecture-mock__node:last-of-type::after {
    display: none;
  }

  .workflow-mock span,
  .architecture-mock span {
    display: block;
    color: #E1E0CC;
  }

  .workflow-mock small,
  .architecture-mock small {
    display: block;
    margin-top: 0.75rem;
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(222, 219, 200, 0.62);
  }

  .workflow-mock__debug {
    position: absolute;
    right: 6%;
    bottom: 8%;
    max-width: 18rem;
    border: 1px solid rgba(222, 219, 200, 0.14);
    border-radius: 8px;
    background: rgba(31, 31, 31, 0.92);
    padding: 1rem;
  }

  .workflow-mock__debug span,
  .map-mock__sheet span {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(222, 219, 200, 0.62);
  }

  .workflow-mock__debug strong,
  .map-mock__sheet strong,
  .map-mock__list strong {
    display: block;
    margin-top: 0.75rem;
    font-weight: 400;
    color: #E1E0CC;
  }

  .workflow-mock__debug p,
  .map-mock__sheet p {
    margin-top: 0.75rem;
    font-size: 0.82rem;
    line-height: 1.55;
    color: rgb(156 163 175);
  }

  .map-mock__grid {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(24deg, transparent 0 37%, rgba(222, 219, 200, 0.16) 38% 39%, transparent 40%),
      linear-gradient(118deg, transparent 0 45%, rgba(222, 219, 200, 0.11) 46% 47%, transparent 48%),
      radial-gradient(circle at 62% 42%, rgba(222, 219, 200, 0.16), transparent 2px);
    background-size: 100% 100%, 100% 100%, 56px 56px;
  }

  .pin {
    position: absolute;
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 999px;
    background: #DEDBC8;
    box-shadow: 0 0 0 0.5rem rgba(222, 219, 200, 0.1);
  }

  .pin--one { left: 28%; top: 38%; }
  .pin--two { left: 57%; top: 46%; }
  .pin--three { left: 74%; top: 28%; }
  .pin--active {
    animation: proof-pulse 2.8s ease-in-out infinite;
  }

  .map-mock__list,
  .map-mock__sheet {
    position: absolute;
    border: 1px solid rgba(222, 219, 200, 0.14);
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.74);
    padding: 1rem;
  }

  .map-mock__list {
    left: 5%;
    bottom: 8%;
    width: min(18rem, 70vw);
  }

  .map-mock__list p {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(222, 219, 200, 0.62);
  }

  .map-mock__list span {
    display: block;
    margin-top: 0.65rem;
    font-size: 0.82rem;
    color: rgb(156 163 175);
  }

  .map-mock__sheet {
    right: 5%;
    top: 10%;
    width: min(17rem, 66vw);
  }

  .session-mock {
    display: grid;
    place-items: center;
  }

  .session-mock__timer {
    font-size: clamp(4.5rem, 13vw, 8rem);
    line-height: 1;
    color: #E1E0CC;
  }

  .session-mock__bar {
    width: min(34rem, 80%);
    height: 0.35rem;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(225, 224, 204, 0.12);
  }

  .session-mock__bar span {
    display: block;
    width: 68%;
    height: 100%;
    background: #DEDBC8;
  }

  .session-mock__people,
  .session-mock__feed {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  .session-mock__people span,
  .session-mock__feed p {
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.45);
    padding: 0.55rem 0.8rem;
    font-size: 0.78rem;
    color: rgb(156 163 175);
  }

  .architecture-mock__node {
    top: 50%;
  }

  @keyframes proof-pulse {
    50% {
      box-shadow: 0 0 0 1.1rem rgba(222, 219, 200, 0.04);
      transform: scale(1.08);
    }
  }

  @media (min-width: 900px) {
    .project-proof {
      grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.55fr);
    }

    .project-proof__moments {
      grid-column: 1 / -1;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .project-proof__visual {
      min-height: 360px;
    }

    .workflow-mock__node,
    .architecture-mock__node {
      left: 50%;
      top: calc(14% + var(--i) * 18%);
    }

    .workflow-mock__node::after,
    .architecture-mock__node::after {
      display: none;
    }

    .workflow-mock__debug {
      right: 1rem;
      left: 1rem;
      bottom: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pin--active {
      animation: none;
    }
  }
</style>
