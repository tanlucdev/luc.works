---
import PhilosophyMotion from './PhilosophyMotion.tsx';
---

<section id="work" aria-labelledby="philosophy-title" class="relative overflow-hidden bg-black px-4 py-20 sm:px-6 md:py-28 lg:py-32">
  <div class="bg-noise pointer-events-none absolute inset-0 opacity-[0.12]"></div>
  <div class="relative z-10 mx-auto max-w-6xl bg-[#101010] px-5 py-16 sm:px-8 sm:py-20 md:px-12 md:py-24 lg:px-16">
    <h2 id="philosophy-title" class="sr-only">Great software should feel invisible.</h2>
    <p class="mb-6 text-center text-[10px] uppercase tracking-[0.28em] text-primary sm:text-xs">Work</p>
    <PhilosophyMotion client:visible />
  </div>
</section>
