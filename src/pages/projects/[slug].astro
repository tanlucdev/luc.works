---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DetailMotion from '../../components/DetailMotion.tsx';
import MarkdownContent from '../../components/MarkdownContent.astro';
import ProjectProof from '../../components/ProjectProof.astro';
import ScrollControls from '../../components/ScrollControls.astro';
import { writing } from '../../data/content';
import type { Writing } from '../../data/content';
import { getProjectBySlug, projects } from '../../data/projects';
import { absoluteUrl, breadcrumbSchema, personSchema } from '../../data/seo';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug }
  }));
}

const project = getProjectBySlug(Astro.params.slug ?? '');

if (!project) {
  return Astro.redirect('/#projects');
}

const projectTitleSpecialty: Record<string, string> = {
  'cinematic-ai': 'AI Workflow Platform Case Study',
  'cafe-maps': 'Map Discovery Product Case Study',
  'study-stream': 'Collaborative Productivity Case Study',
  'engineering-focus': 'Frontend Architecture Case Study'
};

const title = `${project.title} - ${projectTitleSpecialty[project.slug] ?? 'Product Case Study'} | luc.works`;
const canonical = absoluteUrl(`/projects/${project.slug}/`);
const Content = project.Content;

const projectSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  '@id': `${canonical}#creative-work`,
  name: project.title,
  headline: title,
  description: project.summary,
  url: canonical,
  creator: { '@id': 'https://luc.works/#person' },
  about: project.stack,
  keywords: project.stack.join(', ')
};

const relatedWritingByProject: Record<string, string[]> = {
  'cinematic-ai': ['designing-ai-workflows-people-can-debug', 'building-node-based-editors-without-hiding-system-state', 'what-creative-ai-tools-need-besides-generation'],
  'cafe-maps': ['what-creative-ai-tools-need-besides-generation'],
  'study-stream': ['designing-ai-workflows-people-can-debug', 'building-node-based-editors-without-hiding-system-state'],
  'engineering-focus': ['building-node-based-editors-without-hiding-system-state', 'designing-ai-workflows-people-can-debug']
};

const relatedArticles = (relatedWritingByProject[project.slug] ?? [])
  .map((slug) => writing.find((article) => article.slug === slug))
  .filter((article): article is Writing => Boolean(article))
  .slice(0, 3);

const relatedProjects = projects.filter((item) => item.slug !== project.slug).slice(0, 2);
---

<BaseLayout
  title={title}
  description={project.summary}
  canonical={canonical}
  jsonLd={[
    personSchema,
    projectSchema,
    breadcrumbSchema([
      { name: 'Home', url: absoluteUrl('/') },
      { name: 'Projects', url: absoluteUrl('/projects/') },
      { name: project.title, url: canonical }
    ])
  ]}
>
  <main class="min-h-screen bg-black text-[#E1E0CC]">
    <section class="relative px-4 py-6 sm:px-6 md:py-8">
      <div class="bg-noise pointer-events-none absolute inset-0 opacity-[0.14]"></div>
      <div class="relative z-10 mx-auto max-w-7xl">
        <nav aria-label="Project" class="site-nav flex items-center justify-between gap-4 py-3 text-xs text-gray-500 sm:text-sm">
          <a href="/projects" class="transition-colors hover:text-primary">Back to projects</a>
          <div class="flex items-center gap-4">
            <a href="/ask" class="transition-colors hover:text-primary">Ask</a>
            <a href="/#contact" class="transition-colors hover:text-primary">Contact</a>
          </div>
        </nav>

        <h1 class="sr-only">{project.title}</h1>
        <DetailMotion
          eyebrow={`Project ${project.number}`}
          title={project.title}
          summary={project.summary}
          tags={project.stack}
          role={project.role}
          highlights={project.highlights}
          titleClassName="mt-5 text-[18vw] font-medium leading-[0.82] text-[#E1E0CC] sm:text-[15vw] md:text-[12vw] lg:text-[clamp(5rem,8vw,8rem)]"
          client:load
        />

        <section class="border-t border-primary/10 py-12 sm:py-20 md:py-24">
          <div class="grid gap-10 md:grid-cols-12 md:gap-8">
            <div class="md:col-span-3">
              <div class="content-rail-scroll md:sticky md:top-8">
                <p class="text-xs uppercase tracking-[0.24em] text-primary/70">Case Study</p>
                <div class="mt-5 hidden space-y-3 text-sm text-gray-500 md:block">
                  <a href="#artifact" data-smooth-scroll data-section-nav-link class="section-nav-link block transition-colors hover:text-primary">Artifact</a>
                  {project.sectionLinks.map((section) => (
                    <a href={section.href} data-smooth-scroll data-section-nav-link class="section-nav-link block transition-colors hover:text-primary">{section.title}</a>
                  ))}
                  <a href="#related" data-smooth-scroll data-section-nav-link class="section-nav-link block transition-colors hover:text-primary">Related</a>
                </div>
              </div>
            </div>
            <article data-markdown-motion class="content-rail md:col-span-9">
              <div id="artifact" class="scroll-mt-8">
                <ProjectProof project={project} />
              </div>
              <div id="story" class="scroll-mt-8">
                <MarkdownContent>
                  <Content />
                </MarkdownContent>
              </div>
              <div id="related" class="mt-12 scroll-mt-8 border-t border-primary/10 pt-8 sm:mt-14 sm:pt-10">
                <p class="text-xs uppercase tracking-[0.22em] text-primary/70">Related</p>
                <div class="mt-5 grid gap-2 sm:grid-cols-2">
                  {relatedArticles.map((article) => (
                    <a href={`/writing/${article.slug}`} class="group rounded-[8px] bg-[#101010] p-4 transition-colors hover:bg-[#171717] sm:p-5">
                      <p class="text-sm text-primary/70">Writing</p>
                      <h2 class="mt-3 text-lg font-normal leading-tight text-[#E1E0CC]">{article.title}</h2>
                      <p class="mt-3 text-sm leading-relaxed text-gray-500">{article.dek}</p>
                    </a>
                  ))}
                  {relatedProjects.map((item) => (
                    <a href={`/projects/${item.slug}`} class="group rounded-[8px] bg-[#101010] p-4 transition-colors hover:bg-[#171717] sm:p-5">
                      <p class="text-sm text-primary/70">Project</p>
                      <h2 class="mt-3 text-lg font-normal leading-tight text-[#E1E0CC]">{item.title}</h2>
                      <p class="mt-3 text-sm leading-relaxed text-gray-500">{item.description}</p>
                    </a>
                  ))}
                </div>
              </div>
            </article>
          </div>
        </section>
      </div>
    </section>
    <ScrollControls />
  </main>
</BaseLayout>
