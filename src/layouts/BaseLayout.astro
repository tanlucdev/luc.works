---
import '../styles/index.css';

const {
  title = 'Tan Luc — Frontend Engineer & Product Builder',
  description = 'Frontend Engineer building AI-powered products, workflow systems, and thoughtful digital experiences.',
  canonical = 'https://luc.works/'
} = Astro.props;

const siteUrl = 'https://luc.works/';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Tan Luc',
  alternateName: 'Luke',
  jobTitle: ['Frontend Engineer', 'Product Builder', 'AI Workflow Developer'],
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'VN'
  },
  url: siteUrl,
  email: 'hello@luc.works',
  sameAs: ['https://github.com/tanlucdev', 'https://www.linkedin.com/in/tanlucdev/'],
  knowsAbout: ['React', 'TypeScript', 'Next.js', 'AI Workflow Systems', 'Product Development', 'Design Systems', 'Frontend Architecture'],
  description
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#000000" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Tan Luc" />
    <meta property="og:image" content={`${siteUrl}favicon.svg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Almarai:wght@300;400;700;800&family=Instrument+Serif:ital@1&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
